<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cyber Warriors Training (CTF) — Yahya Abdulrahman</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#04050d;
  --accent:#818cf8;
  --accent2:#a5b4fc;
  --accent3:#c7d2fe;
  --text:#f0f0ff;
  --text2:#94a3b8;
  --text3:#475569;
  --mono:'JetBrains Mono',monospace;
  --sans:'Inter',sans-serif;
  --glass:rgba(255,255,255,0.04);
  --glass-b:rgba(255,255,255,0.09);
}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--text);
  font-family:var(--sans);
  min-height:100vh;
  overflow-x:hidden;
}
.orb-layer{
  position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 800px 700px at 10% 15%, rgba(99,102,241,0.13) 0%, transparent 65%),
    radial-gradient(ellipse 600px 500px at 90% 75%, rgba(139,92,246,0.11) 0%, transparent 65%);
}
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  height:64px;padding:0 48px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(4,5,13,0.75);
  backdrop-filter:blur(28px);
  border-bottom:1px solid var(--glass-b);
}
.logo{font-family:var(--mono);font-size:13px;color:var(--accent2);letter-spacing:.08em;text-decoration:none}
.logo em{color:var(--text3);font-style:normal}
.back-btn{
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--mono);font-size:12px;color:var(--text3);
  text-decoration:none;padding:7px 16px;
  border:1px solid var(--glass-b);border-radius:8px;
  transition:color .2s,border-color .2s;
}
.back-btn:hover{color:var(--accent2);border-color:rgba(99,102,241,.4)}
.page{
  position:relative;z-index:1;
  max-width:1000px;margin:0 auto;
  padding:100px 40px 60px;
}
.cert-header{margin-bottom:36px}
.cert-slbl{
  font-family:var(--mono);font-size:11px;color:var(--accent);
  letter-spacing:.15em;text-transform:uppercase;margin-bottom:10px;
}
.cert-title{
  font-size:clamp(24px,4vw,38px);font-weight:700;
  letter-spacing:-.02em;color:#fff;margin-bottom:8px;line-height:1.2;
}
.cert-meta{
  display:flex;flex-wrap:wrap;gap:12px;margin-top:16px;align-items:center;
}
.cbadge{
  display:inline-block;padding:4px 12px;border-radius:100px;
  font-family:var(--mono);font-size:11px;font-weight:600;
  letter-spacing:.08em;text-transform:uppercase;
}
.bp{background:rgba(99,102,241,.15);color:var(--accent2);border:1px solid rgba(99,102,241,.3)}
.bt{background:rgba(16,185,129,.12);color:#34d399;border:1px solid rgba(16,185,129,.25)}
.ba{background:rgba(71,85,105,.2);color:var(--text3);border:1px solid rgba(71,85,105,.3)}
.cert-iss{font-family:var(--mono);font-size:12px;color:var(--text3)}
.cert-date-label{font-family:var(--mono);font-size:12px;color:var(--accent2)}
.cert-id{font-family:var(--mono);font-size:11px;color:var(--text3)}
.cert-viewer{
  background:var(--glass);
  border:1px solid var(--glass-b);
  border-radius:20px;
  overflow:hidden;
  position:relative;
}
.cert-iframe{
  width:100%;
  height:75vh;
  min-height:500px;
  border:none;
  display:block;
}
.cert-img{
  width:100%;
  height:auto;
  display:block;
  border-radius:16px;
}
.cert-footer{
  margin-top:24px;
  display:flex;gap:12px;flex-wrap:wrap;align-items:center;
}
.btn-back{
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 24px;border-radius:10px;
  background:linear-gradient(135deg,#6366f1,#8b5cf6);
  color:#fff;font-weight:600;font-size:14px;text-decoration:none;
  transition:opacity .2s;
}
.btn-back:hover{opacity:.88}
.btn-ghost{
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 24px;border-radius:10px;
  border:1px solid var(--glass-b);color:var(--text2);
  font-size:14px;font-weight:500;text-decoration:none;
  transition:border-color .2s,color .2s;
}
.btn-ghost:hover{border-color:rgba(99,102,241,.4);color:var(--accent2)}
@media(max-width:600px){
  nav{padding:0 20px}
  .page{padding:90px 20px 40px}
  .cert-iframe{height:55vh}
}
</style>
</head>
<body>
<div class="orb-layer"></div>
<nav>
  <a href="index.html" class="logo">yahya<em>@sec</em>:~$ _</a>
  <a href="index.html" class="back-btn">← Back to Portfolio</a>
</nav>
<div class="page">
  <div class="cert-header">
    <div class="cert-slbl">// certification</div>
    <h1 class="cert-title">Cyber Warriors Training (CTF)</h1>
    <div class="cert-meta">
      <span class="cbadge bt">Training Cert</span>
      <span class="cert-iss">National Cyber Security Center of Jordan</span>
      <span class="cert-date-label">2024 · 40 Hours · 8 Days</span>
      
    </div>
  </div>
  <div class="cert-viewer">
    <iframe 
            src="data:application/pdf;base64," 
            class="cert-iframe"
            title="Cyber Warriors Training (CTF)"
        ></iframe>
  </div>
  <div class="cert-footer">
    <a href="index.html" class="btn-back">← Back to Portfolio</a>
    <a href="index.html#certifications" class="btn-ghost">All Credentials</a>
  </div>
</div>
</body>
</html>
